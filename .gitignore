# === Environment files ===
# Ignore all .env files anywhere (local development, production, etc.)
.env
.env.*
!.env.example

# Specific overrides for clarity (optional, already covered by .env.*)
backend/.env
backend/.env.production
frontend/.env
frontend/.env.production

# === Dependencies ===
node_modules/
frontend/node_modules/
backend/node_modules/

# === Build outputs ===
dist/
dist-ssr/
frontend/dist/
backend/public/   # if you ever generate public inside backend

# === Logs ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# === OS generated files ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === Editor directories and files ===
.vscode/*
!.vscode/extensions.json
.idea
*.suo
